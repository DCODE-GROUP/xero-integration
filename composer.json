{
    "name": "dcode-group/xero-integration",
    "description": "An opininated Xero integration package for Laravel that allows for fluent quering of Xero records and mapping of Xero Entities",
    "keywords": [
        "Dcode Group",
        "laravel",
        "xero",
        "xero-integration"
    ],
    "homepage": "https://github.com/dcode-group/xero-integration",
    "license": "MIT",
    "version": "0.1.0",
    "authors": [
        {
            "name": "Dcode Group",
            "email": "forge@dcodegroup.com",
            "homepage": "https://dcodegroup.com"
        },
        {
            "name": "Josh Young",
            "email": "jny986@gmail.com",
            "homepage": "https://jny986.com"
        }
    ],
    "require": {
        "php": "^8.4",
        "calcinai/xero-php": "^2.8",
        "illuminate/contracts": "^10.0||^11.0||^12.0||^13.0",
        "illuminate/support": "^10.0||^11.0||^12.0||^13.0",
        "laravel/prompts": "^0.1.9",
        "league/oauth2-client": "^2.9",
        "spatie/laravel-data": "^4.23",
        "spatie/laravel-package-tools": "^1.16"
    },
    "require-dev": {
        "laravel/pint": "^1.14",
        "nunomaduro/collision": "^8.8",
        "larastan/larastan": "^3.0",
        "orchestra/testbench": "^8.0.0||^9.0.0||^10.0.0||^11.0.0",
        "pestphp/pest": "^3.0||^4.0",
        "pestphp/pest-plugin-arch": "^3.0||^4.0",
        "pestphp/pest-plugin-laravel": "^3.0||^4.0",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "DcodeGroup\\XeroIntegration\\": "src/",
            "DcodeGroup\\XeroIntegration\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "DcodeGroup\\XeroIntegration\\Tests\\": "tests/",
            "Workbench\\App\\": "workbench/app/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@composer run prepare",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "analyse": "vendor/bin/phpstan analyse",
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "DcodeGroup\\XeroIntegration\\XeroIntegrationServiceProvider"
            ],
            "aliases": {
                "XeroIntegration": "DcodeGroup\\XeroIntegration\\Facades\\XeroIntegration"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
